{
  "name": "doc-mind",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "start": "npm run start --workspace=services/api",
    "dev:back": "npm run start:dev --workspace=services/api",
    "dev:front": "npm run dev --workspace=apps/web",
    "services": "docker compose -f infra/docker/docker-compose.dev.yml up -d --force-recreate",
    "services:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vite-plugin-svgr": "^5.2.0"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "dependencies": {
    "@tanstack/react-table": "^8.21.3"
  }
}

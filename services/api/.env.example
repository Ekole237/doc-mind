NODE_ENV=test

DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres


JWT_SECRET=test-secret-key-minimum-32-characters-long
JWT_EXPIRY=8h


QDRANT_URL=
QDRANT_COLLECTION=

OPENAI_API_KEY=sk-test
LLM_PROVIDER=mock

UPLOAD_DIR=./uploads

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu


SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
MAIL_FROM=
APP_PUBLIC_URL=

FRONTEND_URL=

# ALTCHA (Proof-of-Work CAPTCHA)
ALTCHA_HMAC_KEY=

# GROQ API OPENAI_API_KEY
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_API_KEY=
EMBEDDING_DIMENSIONS=384
SIMILARITY_THRESHOLD=0.5
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# File storage : local pour dev, s3 pour prod
STORAGE_PROVIDER=local


LOCAL_STORAGE_PATH=./uploads

# Cloudflare R2 (ancienne configuration)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# AWS S3 (nouvelle configuration)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

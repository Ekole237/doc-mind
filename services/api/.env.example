# ========================================
# REQUIRED VARIABLES (Basic Backend Functionality)
# ========================================

# Environment
NODE_ENV=test

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/postgres

# JWT Authentication
JWT_SECRET=test-secret-key-minimum-32-characters-long
JWT_EXPIRY=8h

# Vector Search (Qdrant)
QDRANT_URL=
QDRANT_COLLECTION=

# File Storage (local or s3)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads

# Application URLs
APP_PUBLIC_URL=
FRONTEND_URL=

# OAuth Providers
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu

# ========================================
# OPTIONAL INTEGRATIONS
# ========================================

# Email/SMTP Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
MAIL_FROM=

# CAPTCHA (Future Implementation)
ALTCHA_HMAC_KEY=

# Legacy Storage (Cloudflare R2 - deprecated)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ========================================
# EXTERNAL/PAID SERVICES (free plan are available but not recommended for production)
# ========================================

# AI/LLM Services
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=sk-test

# Embedding Services
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_API_KEY=
EMBEDDING_DIMENSIONS=384
SIMILARITY_THRESHOLD=0.5

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
